# Copia este archivo a .env y completa los valores (no subas .env a git)

# Odoo XML-RPC
ODOO_URL=
ODOO_DB=
ODOO_USER=
ODOO_PASSWORD=

# Opcional — si el panel no detecta la empresa por nombre en Odoo (res.company id):
# ODOO_BRAVOS_COMPANY_ID=
# ODOO_BOX_PRIME_COMPANY_ID=

# Sesión del panel web (login)
# Opción A — un solo usuario (clásico):
DASHBOARD_LOGIN_EMAIL=
DASHBOARD_PASSWORD=
# Opción B — varios usuarios (JSON en una sola variable; si está definida, tiene prioridad sobre A):
# DASHBOARD_USERS=[{"email":"uno@empresa.com","password":"Secreto1"},{"email":"dos@empresa.com","password":"Secreto2"}]
FLASK_SECRET_KEY=

# Producción HTTPS (Vercel): descomenta
# SESSION_COOKIE_SECURE=1
