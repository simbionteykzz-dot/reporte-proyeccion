{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": "public/**"
    },
    "app.py": {
      "includeFiles": "public/**"
    },
    "backend/app.py": {
      "includeFiles": "public/**"
    }
  }
}
