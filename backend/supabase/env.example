# Supabase base configuration (server-side)
SUPABASE_URL=https://your-project-ref.supabase.co

# Prefer service role key for backend integrations.
# If you still do read-only tests, you can set SUPABASE_ANON_KEY instead.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ANON_KEY=your-anon-key

# Optional: table used for Zazu Envios tab.
# SUPABASE_ZAZU_TABLE=tb_envios_diarios_lina

# Optional: PostgREST select/order customization for Zazu table.
# SUPABASE_ZAZU_SELECT=*,envio:tb_envios_lima!id_envio(*),motorizado:tb_motorizado!id_motorizado(*)
# SUPABASE_ZAZU_ORDER=id.desc
