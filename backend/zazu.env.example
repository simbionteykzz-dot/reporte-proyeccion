# Opción A: variables en la raíz del repo en .env (como Odoo).
# Opción B: archivo api/.env en el repo — web_app.py lo carga con override=False.
# Ver GET /api/health → deployment.zazu_supabase_configured

ZAZU_SUPABASE_URL=https://TU_REF.supabase.co
ZAZU_SUPABASE_ANON_KEY=tu_jwt_anon

# Si las políticas RLS de Supabase exigen usuario autenticado:
# ZAZU_SUPABASE_JWT=tu_jwt_sesion_o_service
